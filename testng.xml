<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SensaraAPISuite">

	<listeners>
		<listener class-name="api.utility.ict.ExtentReportManager" />
	</listeners>
	
	<test name="API Alarm Tests">
		<groups>
			<run>
				<include name="alarms" />
			</run>
		</groups>
		<classes>
			<class name="api.tests.ict.OutOfBedAlarmStatusGeneration"/>
			<class name="api.tests.ict.OutOfChairAlarmStatusGeneration"/>
			
			<class name="api.tests.ict.OutOfBedAlarmVideoGeneration"/>
			<class name="api.tests.ict.OutOfChairAlarmVideoGeneration"/>
			<class name="api.tests.ict.FallDetectionAlarmVideoGeneration"/>	
		</classes>
	</test>
	
	
</suite>